
# Base de données PostgreSQL
DATABASE_URL=postgresql://nawras:ChangezMeEnProduction!@localhost:5432/nawras_erp

# Clé secrète des sessions (générez une chaîne aléatoire longue)
# Exemple : openssl rand -hex 64
SESSION_SECRET=changez-moi-avec-une-chaine-aleatoire-tres-longue

# Port du serveur API
PORT=3001

# Environnement
NODE_ENV=production
